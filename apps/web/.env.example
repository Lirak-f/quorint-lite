# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key      # safe to expose — RLS enforced

# ── Paddle (client-side) ───────────────────────────────────────────────────────
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...          # Paddle dashboard → Authentication → Client-side tokens
NEXT_PUBLIC_PADDLE_ENV=sandbox                    # "sandbox" or "production"

# ── App URLs ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000         # used for Paddle checkout return URL
NEXT_PUBLIC_API_URL=http://localhost:8000         # FastAPI backend base URL

# ── Analytics ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...                  # PostHog project API key (posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com  # or https://us.i.posthog.com

# ── Observability ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=                          # https://...@sentry.io/... (optional)
