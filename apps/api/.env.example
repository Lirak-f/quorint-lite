# ── AI models ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # All Claude workers (Sonnet 4.6) — production path
GEMINI_API_KEY=              # Gemini 2.0 Flash — dev/test fallback (aistudio.google.com/apikey)
PERPLEXITY_API_KEY=          # Workers 3 (Sonar Pro) and 4 (Sonar Deep Research)

# ── Data APIs ──────────────────────────────────────────────────────────────────
SCRAPERAPI_KEY=              # Google Shopping geo-targeted price scraping (free: 1k/month)
APOLLO_API_KEY=              # Buyer contact discovery (free: 10k credits/month)
PDL_API_KEY=                 # Contact enrichment fallback (free: 100 records/month)
EXCHANGERATE_API_KEY=        # FX rates + 90-day range (free: 1,500/month)
TENTIMES_API_KEY=            # Trade fair exhibitor data (free tier)

# ── Observability ──────────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=         # sk-lf-...
LANGFUSE_PUBLIC_KEY=         # pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Infrastructure ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=

# ── Payments (Paddle) ──────────────────────────────────────────────────────────
PADDLE_API_KEY=                       # server-side API key (from Paddle dashboard)
PADDLE_NOTIFICATION_WEBHOOK_SECRET=   # from Paddle dashboard → Notifications
PADDLE_PRICE_ID_STARTER=              # pri_xxx for €29 one-time
PADDLE_PRICE_ID_FULL=                 # pri_xxx for €49 one-time
PADDLE_PRICE_ID_COPILOT=              # pri_xxx for €299/month subscription

# ── Internal test ──────────────────────────────────────────────────────────────
INTERNAL_TEST_TOKEN=         # Random string — NEVER expose to frontend

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
